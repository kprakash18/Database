# ── Express Server Configuration ──
PORT=3000
NODE_ENV=development

# ── Local Development Database URL ──
# Point this to your local PostgreSQL instance
# Format: postgresql://<user>:<password>@localhost:5432/<db_name>
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/indian_food_dev"

# ── Production Supabase Connection URI ──
# (Comment this out locally to trigger Safety Guard protection)
# SUPABASE_URI="postgresql://postgres.<project_ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# ── Database Connection Pool Settings ──
DATABASE_POOL_MAX=10

# ── CORS Allowed Domain ──
# CORS_ORIGIN=https://your-frontend-domain.vercel.app

# ── API Documentation Hosted Domain (Swagger) ──
# SERVER_URL=https://your-backend-api.onrender.com
